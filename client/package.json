{
  "name": "vue-media-annotator",
  "version": "1.9.11",
  "author": {
    "name": "Kitware, Inc.",
    "email": "viame-web@kitware.com"
  },
  "description": "DIVE annotation platform",
  "homepage": "https://kitware.github.io/dive",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "npm run serve",
    "dev:electron": "npm run serve:electron",
    "dev:electron:windows": "npm run serve:electron:windows",
    "serve": "vite",
    "serve:electron": "mkdir -p /tmp/dive-electron && cross-env ELECTRON_RUN_AS_NODE= ELECTRON_DISABLE_SECURITY_WARNINGS=true TMPDIR=/tmp/dive-electron XDG_RUNTIME_DIR=/tmp/dive-electron electron-vite dev --entry=.electron/main/background.js",
    "serve:electron:windows": "cross-env ELECTRON_DISABLE_SECURITY_WARNINGS=true electron-vite dev --entry=.electron/main/background.js",
    "build:web": "vite build",
    "build:electron": "electron-vite build && electron-builder --config electron-builder.json",
    "divecli": "node ./bin/platform/desktop/backend/cli.js",
    "lint": "eslint --ext .js,.ts,.vue src/ dive-common/ platform/",
    "lint:templates": "eslint --ext vue src/ dive-common/ platform/",
    "test": "vitest run src/ dive-common/ platform/",
    "postinstall": "patch-package"
  },
  "files": [
    "/src",
    "/bin/"
  ],
  "bin": {
    "divecli": "./bin/platform/desktop/backend/cli.js"
  },
  "dependencies": {
    "@flatten-js/interval-tree": "^1.1.4",
    "@fontsource/roboto": "^5.2.7",
    "@girder/components": "github:girder/girder_web_components#girder-5-websocket-configurable",
    "@mdi/font": "^6.9.96",
    "@sentry/browser": "^5.30.0",
    "@sentry/integrations": "^5.30.0",
    "axios": "^1.17.0",
    "csv-stringify": "^5.6.5",
    "d3": "^5.16.0",
    "geojs": "~1.19.1",
    "js-cookie": "^3.0.8",
    "geotiff": "^3.0.5",
    "glob-to-regexp": "^0.4.1",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "mousetrap": "^1.6.5",
    "pngjs": "^7.0.0",
    "qs": "^6.15.2",
    "semver": "^7.8.4",
    "vue": "^3.5.38",
    "vue-gtag": "^2.1.2",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.8"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.7",
    "@types/body-parser": "^1.19.6",
    "@types/cors": "^2.8.19",
    "@types/csv-parse": "^1.2.5",
    "@types/d3": "^5.16.7",
    "@types/express": "^4.17.25",
    "@types/geojson": "^7946.0.16",
    "@types/glob-to-regexp": "^0.4.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.24",
    "@types/mime-types": "^2.1.4",
    "@types/mock-fs": "^4.13.4",
    "@types/mousetrap": "^1.6.15",
    "@types/node": "^25.9.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/qs": "^6.15.1",
    "@types/pump": "^1.1.3",
    "@types/range-parser": "^1.2.7",
    "@types/resize-observer-browser": "^0.1.11",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/eslint-config-airbnb": "^7.0.1",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "body-parser": "^1.20.5",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "csv-parse": "^4.16.3",
    "electron": "^41.7.2",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^9.33.0",
    "express": "^4.22.2",
    "ffmpeg-ffprobe-static": "^6.1.2-rc.1",
    "fs-extra": "^9.1.0",
    "js-yaml": "^4.2.0",
    "jsdom": "^24.1.3",
    "mime-types": "^2.1.35",
    "mock-fs": "^5.5.0",
    "patch-package": "^8.0.1",
    "proper-lockfile": "^4.1.2",
    "pump": "^3.0.4",
    "range-parser": "^1.2.1",
    "sass": "^1.101.0",
    "tsc-alias": "^1.8.17",
    "tslib": "^2.8.1",
    "typescript": "~4.9.5",
    "vite": "^6.4.3",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^3.2.6",
    "webpack": "^5.107.2",
    "wslink": "^2.5.0",
    "xml-js": "^1.6.11",
    "yargs": "^16.2.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:vue/recommended",
      "@vue/airbnb"
    ],
    "rules": {
      "no-underscore-dangle": 0,
      "spaced-comment": "off",
      "no-useless-constructor": "off",
      "no-use-before-define": "off",
      "vue/require-valid-default-prop": "off",
      "vue/require-default-prop": "off",
      "vue/no-unused-components": "off",
      "vue/valid-v-slot": "off",
      "vuejs-accessibility/alt-text": "off",
      "vue/no-v-text-v-html-on-component": "off",
      "@typescript-eslint/no-unused-vars": "off",
      "vue/no-template-target-blank": "off",
      "vue/no-lone-template": "off",
      "vuejs-accessibility/mouse-events-have-key-events": "off",
      "vuejs-accessibility/click-events-have-key-events": "off",
      "vue/no-v-model-argument": "off",
      "vue/no-mutating-props": "off",
      "no-promise-executor-return": "off",
      "no-shadow": "off",
      "vue/multi-word-component-names": "off",
      "vuejs-accessibility/form-control-has-label": "off",
      "@typescript-eslint/ban-ts-comment": "off",
      "@typescript-eslint/ban-ts-ignore": "off",
      "@typescript-eslint/no-useless-constructor": "error",
      "import/extensions": "off",
      "vue/max-len": "off",
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error"
          ]
        }
      ],
      "semi": "off",
      "@typescript-eslint/semi": [
        "error"
      ]
    },
    "settings": {
      "import/resolver": {
        "typescript": {}
      },
      "import/core-modules": [
        "@girder/components",
        "@girder/components/plugins/vuetifyConfig.js",
        "vuetify/styles"
      ]
    },
    "overrides": [
      {
        "files": [
          "**/*.ts",
          "**/*.vue"
        ],
        "extends": [
          "@vue/typescript",
          "@vue/typescript/recommended"
        ]
      }
    ],
    "parserOptions": {
      "parser": "@typescript-eslint/parser",
      "ecmaVersion": 2020
    }
  }
}
