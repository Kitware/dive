{
  "name": "vue-media-annotator",
  "version": "1.9.10",
  "author": {
    "name": "Kitware, Inc.",
    "email": "viame-web@kitware.com"
  },
  "description": "DIVE annotation platform",
  "homepage": "https://kitware.github.io/dive",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "npm run serve",
    "dev:electron": "npm run serve:electron",
    "serve": "vite",
    "serve:electron": "mkdir -p /tmp/dive-electron && cross-env ELECTRON_RUN_AS_NODE= ELECTRON_DISABLE_SECURITY_WARNINGS=true TMPDIR=/tmp/dive-electron XDG_RUNTIME_DIR=/tmp/dive-electron electron-vite dev --entry=.electron/main/background.js",
    "build:web": "vite build",
    "build:electron": "electron-vite build && electron-builder --config electron-builder.json",
    "build:cli": "tsc -b tsconfig.cli.json && tsc-alias -p tsconfig.cli.json",
    "dev:cli": "tsc -w -p tsconfig.cli.json & tsc-alias -w -p tsconfig.cli.json",
    "divecli": "node ./bin/platform/desktop/backend/cli.js",
    "lint": "eslint --ext .js,.ts,.vue src/ dive-common/ platform/",
    "lint:templates": "eslint --ext vue src/ dive-common/ platform/",
    "test": "vitest run src/ dive-common/ platform/"
  },
  "files": [
    "/src",
    "/bin/"
  ],
  "bin": {
    "divecli": "./bin/platform/desktop/backend/cli.js"
  },
  "dependencies": {
    "@flatten-js/interval-tree": "^1.0.11",
    "@girder/components": "^3.2.0",
    "@mdi/font": "^6.2.95",
    "@sentry/browser": "^5.24.2",
    "@sentry/integrations": "^5.24.2",
    "axios": "^0.21.1",
    "csv-stringify": "^5.6.0",
    "d3": "^5.12.0",
    "geojs": "~1.6.2",
    "geotiff": "^3.0.0",
    "pngjs": "^7.0.0",
    "glob-to-regexp": "^0.4.1",
    "lodash": "^4.17.19",
    "moment": "^2.29.1",
    "mousetrap": "^1.6.5",
    "semver": "^7.3.5",
    "vue": "^2.7.16",
    "vue-gtag": "^1.9.1",
    "vue-router": "^3.0.3",
    "vuetify": "^2.7.1",
    "vuex": "^3.0.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.0",
    "@types/cors": "^2.8.9",
    "@types/csv-parse": "^1.2.2",
    "@types/d3": "^5.7.2",
    "@types/express": "^4.17.9",
    "@types/geojson": "^7946.0.7",
    "@types/glob-to-regexp": "^0.4.0",
    "@types/js-yaml": "^4.0.5",
    "@types/lodash": "^4.14.151",
    "@types/mime-types": "^2.1.0",
    "@types/mock-fs": "^4.13.1",
    "@types/mousetrap": "^1.6.3",
    "@types/node": "^25.6.0",
    "@types/proper-lockfile": "^4.1.1",
    "@types/pump": "^1.1.0",
    "@types/range-parser": "^1.2.3",
    "@types/resize-observer-browser": "^0.1.4",
    "@types/semver": "^7.3.8",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-vue2": "^2.3.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/eslint-config-airbnb": "^7.0.1",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^1.0.3",
    "autoprefixer": "^10.4.21",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "csv-parse": "^4.13.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^8.55.0",
    "eslint-import-resolver-typescript": "^2.2.0",
    "eslint-plugin-import": "^2.20.2",
    "eslint-plugin-vue": "^9.26.0",
    "express": "^4.17.1",
    "ffmpeg-ffprobe-static": "^4.4.0-rc.11",
    "fs-extra": "^9.0.1",
    "js-yaml": "^4.1.0",
    "mime-types": "^2.1.27",
    "mock-fs": "^5.2.0",
    "proper-lockfile": "^4.1.1",
    "pump": "^3.0.0",
    "range-parser": "^1.2.1",
    "sass": "~1.32.6",
    "tsc-alias": "^1.2.0",
    "tslib": "^2.6.2",
    "typescript": "~4.3.5",
    "vite": "^5.4.20",
    "vitest": "^3.2.4",
    "vue-template-compiler": "^2.7.16",
    "xml-js": "^1.6.11",
    "yargs": "^16.1.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:vue/recommended",
      "@vue/airbnb"
    ],
    "rules": {
      "no-underscore-dangle": 0,
      "spaced-comment": "off",
      "no-useless-constructor": "off",
      "no-use-before-define": "off",
      "vue/require-valid-default-prop": "off",
      "vue/require-default-prop": "off",
      "vue/no-unused-components": "off",
      "vue/valid-v-slot": "off",
      "vuejs-accessibility/alt-text": "off",
      "vue/no-v-text-v-html-on-component": "off",
      "@typescript-eslint/no-unused-vars": "off",
      "vue/no-template-target-blank": "off",
      "vue/no-lone-template": "off",
      "vuejs-accessibility/mouse-events-have-key-events": "off",
      "vuejs-accessibility/click-events-have-key-events": "off",
      "vue/no-mutating-props": "off",
      "no-promise-executor-return": "off",
      "no-shadow": "off",
      "vue/multi-word-component-names": "off",
      "vuejs-accessibility/form-control-has-label": "off",
      "@typescript-eslint/ban-ts-comment": "off",
      "@typescript-eslint/ban-ts-ignore": "off",
      "@typescript-eslint/no-useless-constructor": "error",
      "import/extensions": "off",
      "vue/max-len": "off",
      "no-console": [
        "warn",
        {
          "allow": [
            "warn",
            "error"
          ]
        }
      ],
      "semi": "off",
      "@typescript-eslint/semi": [
        "error"
      ]
    },
    "settings": {
      "import/resolver": {
        "typescript": {}
      }
    },
    "overrides": [
      {
        "files": [
          "**/*.ts",
          "**/*.vue"
        ],
        "extends": [
          "@vue/typescript",
          "@vue/typescript/recommended"
        ]
      }
    ],
    "parserOptions": {
      "parser": "@typescript-eslint/parser",
      "ecmaVersion": 2020
    }
  }
}
